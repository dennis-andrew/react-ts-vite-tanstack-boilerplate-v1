{
  "name": "react-ts-antd-vite-boilerplate",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-router": "^1.170.15",
    "antd": "^5.22.5",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "hammerjs": "^2.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-otp-input": "^3.1.1",
    "sass": "^1.83.0",
    "serializr": "^3.0.2",
    "typescript": "^5.7.2",
    "yup": "^1.6.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:staging": "env-cmd -f .env.staging vite",
    "dev:production": "env-cmd -f .env.production vite",
    "build": "tsc && vite build",
    "build:staging": "env-cmd -f .env.staging vite build",
    "build:production": "env-cmd -f .env.production vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest --run --coverage",
    "coverage": "vitest --run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:all": "oxlint . && prettier --check .",
    "lint:fix:all": "oxlint --fix . && prettier --write .",
    "format": "prettier --write .",
    "lighthouse": "lhci autorun",
    "prepare": "husky",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@lhci/cli": "^0.15.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.18.13",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.7",
    "conventional-changelog-atom": "^5.0.0",
    "env-cmd": "^11.0.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "oxlint": "^1.26.0",
    "prettier": "^3.6.2",
    "vite": "^6.4.1",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.7"
  }
}
